{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: checks",
      "type": "shell",
      "command": "npm run checks",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$tsc",
        "$eslint-stylish"
      ]
    }
  ]
}